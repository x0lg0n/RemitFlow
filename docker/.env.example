# RemitFlow Docker Environment Configuration
# ⚠️  COPY THIS FILE TO .env AND FILL IN YOUR SECRETS
# ⚠️  NEVER COMMIT .env TO GIT - IT'S IN .gitignore

# ===========================================
# JWT Authentication
# ===========================================
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-generate-with-openssl-rand-base64-32
JWT_EXPIRY_HOURS=24

# ===========================================
# SEP-10 Authentication
# ===========================================
# Generate a Stellar keypair for SEP-10 server
# Use: stellar keys generate --network testnet
SEP10_SERVER_SECRET=your-sep10-server-secret-key
SEP10_HOME_DOMAIN=localhost
SEP10_WEB_AUTH_DOMAIN=localhost

# ===========================================
# Database Configuration
# ===========================================
# Change these for production!
POSTGRES_DB=remitflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-database-password
DATABASE_URL=postgresql://postgres:your_secure_password_here@db:5432/remitflow

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Stellar Network
# ===========================================
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_CONTRACT_ADDRESS=CAN4U3NRPWV7IPDUSKWAYMTHWNSFH4ZRJGA7KMEDKLYJCJCCJNV6TXF7

# ===========================================
# Oracle Configuration
# ===========================================
# Generate oracle keypair: stellar keys generate --network testnet
ORACLE_SECRET_KEY=your-oracle-secret-key
ORACLE_USE_RATE_CALLBACK_ONLY=true
POLL_INTERVAL_MINUTES=5
MAX_DEVIATION_PERCENT=5
MAX_CONSECUTIVE_FAILURES=3

# ===========================================
# Anchor API Configurations
# Format: ANCHOR_CONFIGS=id|baseUrl|authToken (comma-separated for multiple)
# ===========================================
# Example:
# ANCHOR_CONFIGS=vibrant_colombia|https://api.vibrantapp.com|your-vibrant-api-token,bantr_nigeria|https://api.bantr.io|your-bantr-api-token
ANCHOR_CONFIGS=

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGINS=http://localhost:3000

# ===========================================
# Node Environment
# ===========================================
NODE_ENV=development
SESSION_COOKIE_NAME=remitflow_session
