{
  "name": "remitflow-backend",
  "version": "0.1.0",
  "description": "RemitFlow backend API server — rate comparison, transaction management, SEP-10 auth",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "15.0.1",
    "axios": "1.15.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-rate-limit": "8.3.2",
    "helmet": "8.1.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.6.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.4",
    "typescript-eslint": "8.59.0",
    "eslint": "10.2.0",
    "globals": "17.5.0",
    "jest": "30.3.0",
    "ts-jest": "29.4.9",
    "ts-node-dev": "2.0.0",
    "typescript": "6.0.2"
  }
}
