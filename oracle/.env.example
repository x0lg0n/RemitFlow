# Environment
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remiflow

# Redis
REDIS_URL=redis://localhost:6379

# Stellar Soroban RPC
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_CONTRACT_ADDRESS=

# Oracle keypair (secret seed, 64 hex chars)
ORACLE_SECRET_KEY=

# Anchor API configs (comma-separated for multiple anchors)
# Format: id|baseUrl|authToken
# Example: anchor_colombia|https://anchor-co.example.com|token-abc
ANCHOR_CONFIGS=

# Polling interval (minutes)
POLL_INTERVAL_MINUTES=5

# Validation
MAX_DEVIATION_PERCENT=5
MAX_CONSECUTIVE_FAILURES=3
